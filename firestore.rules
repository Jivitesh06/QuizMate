rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Topics: Anyone logged in can read topics
    match /topics/{topicId} {
      allow read: if request.auth != null;
      allow write: if false; // Admins write server-side
    }

    // Questions: Clients cannot read questions directly to prevent cheating
    match /questions/{questionId} {
      allow read, write: if false; // Server-side only
    }

    // Tests: Clients cannot read the test details (which contain questionIds) directly
    match /tests/{testId} {
      allow read, write: if false; // Server-side only
    }

    // Attempts: Authenticated users can read their own attempts, and create new ones
    match /attempts/{attemptId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false; // Attempts are immutable for students
    }
  }
}
