rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'jiviteshgarg30@gmail.com';
    }

    function isLoggedIn() {
      return request.auth != null;
    }

    // Topics: All logged-in users can read. Only admin can write.
    match /topics/{topicId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Questions: All logged-in users can read (needed for quiz + result review).
    // Only admin can write.
    match /questions/{questionId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Tests: Any logged-in user can create and read their own test.
    match /tests/{testId} {
      allow create: if isLoggedIn();
      allow read: if isLoggedIn();
      allow update, delete: if isAdmin();
    }

    // Attempts: Users can read their own. Admin can read all. Users can create their own.
    match /attempts/{attemptId} {
      allow read: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // Users: Users can write/read their own profile. Admin can read all.
    match /users/{userId} {
      allow read: if isLoggedIn() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isLoggedIn() && request.auth.uid == userId;
      allow delete: if false;
    }
  }
}
