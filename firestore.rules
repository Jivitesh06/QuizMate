rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'jiviteshgarg30@gmail.com';
    }

    function isLoggedIn() {
      return request.auth != null;
    }

    // Topics: All logged-in users can read. Only admin can write.
    match /topics/{topicId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Questions: All logged-in users can read (needed for quiz).
    // Only admin can write.
    match /questions/{questionId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // Tests: Admin only
    match /tests/{testId} {
      allow read, write: if isAdmin();
    }

    // Attempts: Users can read their own. Users can create their own.
    match /attempts/{attemptId} {
      allow read: if isLoggedIn() && resource.data.userId == request.auth.uid;
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
